# Copy to .env and fill real values when ready (never commit)
#   cp .env.example .env

DEMO_MODE=true

# Host-local default. docker-compose.yml overrides to redis://redis:6379/0 inside containers.
REDIS_URL=redis://localhost:6379/0

# Snowflake (Phase 2) — use read-only role for dashboard, write role only via rituals
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=ALPHAGEN_ETRM
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
